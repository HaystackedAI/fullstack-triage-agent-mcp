{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "mcp3",
  "version": 2,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "mcp3"
  },
  "runtimes": [
    {
      "name": "TaskManager",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/TaskManager/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "instrumentation": {
        "enableOtel": false
      },
      "protocol": "MCP",
      "envVars": [
        {
          "name": "BACKEND_URL",
          "value": "https://haystackedai.fastapicloud.dev"
        }
      ]
    }
  ],
  "memories": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": [],
  "harnesses": [],
  "datasets": [],
  "payments": []
}